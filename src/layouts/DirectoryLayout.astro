---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/directory/Breadcrumbs.astro';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description?: string;
  breadcrumbs: BreadcrumbItem[];
}

const { title, description, breadcrumbs } = Astro.props;
---

<BaseLayout title={`${title} | VibeCoders`} description={description}>
  <div class="bg-brand-white min-h-screen">
    <!-- Page header -->
    <div class="max-w-[1440px] mx-auto px-6 pt-8 pb-6">
      <Breadcrumbs items={breadcrumbs} />
      <h1 class="font-bold text-[32px] md:text-[48px] leading-[0.95] text-brand-black mt-4">
        {title}
      </h1>
    </div>

    <!-- Page content -->
    <div class="max-w-[1440px] mx-auto px-6 pb-16">
      <slot />
    </div>
  </div>
</BaseLayout>
