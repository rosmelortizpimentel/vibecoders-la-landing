---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/directory/Breadcrumbs.astro';
import TagList from '@/components/editorial/TagList.astro';
import SpeakerCard from '@/components/editorial/SpeakerCard.astro';
import VideoEmbed from '@/components/editorial/VideoEmbed.astro';
import CTAButton from '@/components/ui/CTAButton.astro';
import { platformCTA } from '@/lib/urls';

interface Speaker {
  name: string;
  username?: string;
  role: string;
  bio: string;
  avatarUrl?: string;
  linkedinUrl?: string;
  twitterUrl?: string;
  websiteUrl?: string;
  githubUrl?: string;
  youtubeUrl?: string;
  lovableUrl?: string;
}

interface Resource {
  label: string;
  url: string;
  type: 'article' | 'tool' | 'repo' | 'video' | 'link' | 'download' | 'other';
}

interface Timestamp {
  seconds: number;
  label: string;
}

interface Props {
  title: string;
  tagline: string;
  sessionNumber: number;
  speaker: Speaker;
  recordedAt: Date;
  videoUrl?: string;
  videoEmbedId?: string;
  topics: string[];
  resources: Resource[];
  timestamps: Timestamp[];
  durationMinutes?: number;
  notesHtml?: string;
}

const {
  title,
  tagline,
  sessionNumber,
  speaker,
  recordedAt,
  videoUrl,
  videoEmbedId,
  topics,
  resources,
  timestamps,
  durationMinutes,
  notesHtml,
} = Astro.props;

const formattedDate = recordedAt.toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

function formatSeconds(seconds: number): string {
  const m = Math.floor(seconds / 60);
  const s = seconds % 60;
  return `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
}

const resourceIconMap: Record<string, string> = {
  article: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>',
  tool: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>',
  repo: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>',
  video: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="2" y1="7" x2="7" y2="7"/><line x1="2" y1="17" x2="7" y2="17"/><line x1="17" y1="17" x2="22" y2="17"/><line x1="17" y1="7" x2="22" y2="7"/></svg>',
  link: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>',
  download: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>',
  other: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>',
};

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Charlas', href: '/charlas' },
  { label: title },
];

const hasVideo = Boolean(videoUrl || videoEmbedId);
---

<BaseLayout title={`${title} | Charlas | VibeCoders`} description={tagline}>
  <!-- Breadcrumbs -->
  <div class="bg-brand-white max-w-[1440px] mx-auto px-6 pt-6">
    <Breadcrumbs items={breadcrumbs} />
  </div>

  <!-- Dark Hero -->
  <section class="bg-brand-black py-12 md:py-20">
    <div class="max-w-[1440px] mx-auto px-6">
      <div class={`grid grid-cols-1 ${hasVideo ? 'lg:grid-cols-2' : ''} gap-12 items-start`}>
        <!-- Left: info -->
        <div>
          <!-- Session badge -->
          <div class="mb-6">
            <span class="text-xs font-bold uppercase tracking-wider px-2 py-0.5 bg-brand-yellow text-brand-black rounded-none">
              Sesión #{sessionNumber}
            </span>
          </div>

          <!-- Title -->
          <h1 class="font-bold text-[32px] md:text-[40px] leading-[0.95] text-brand-white mb-4">
            {title}
          </h1>

          <!-- Tagline -->
          <p class="text-base leading-relaxed mb-8" style="color: #D9D9D6;">
            {tagline}
          </p>

          <!-- Date + duration -->
          <p class="text-sm mb-8" style="color: #888888;">
            {formattedDate}
            {durationMinutes && ` · ${durationMinutes} min`}
          </p>

          <!-- Speaker -->
          <SpeakerCard speaker={speaker} onDark={true} showBio={false} />

          <!-- Topics -->
          {topics.length > 0 && (
            <div class="mt-8">
              <TagList tags={topics} variant="topic" />
            </div>
          )}
        </div>

        <!-- Right: Video embed -->
        {hasVideo && (
          <div>
            <VideoEmbed videoUrl={videoUrl} videoEmbedId={videoEmbedId} title={title} />
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Light Content -->
  <section class="bg-brand-white py-12">
    <div class="max-w-[1440px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main content -->
        <div class="lg:col-span-2">
          <article class="prose prose-lg max-w-none prose-headings:text-brand-black prose-headings:font-bold prose-a:text-brand-blue prose-a:no-underline hover:prose-a:underline prose-strong:text-brand-black prose-code:bg-surface-silver prose-code:text-brand-black prose-code:rounded-none prose-pre:rounded-none">
            <slot />
          </article>

          <!-- CTA -->
          <div class="mt-16 pt-8 border-t border-border">
            <p class="text-sm font-bold text-brand-black mb-4 uppercase tracking-wider">
              ¿Quieres participar en las próximas charlas en vivo?
            </p>
            <CTAButton
              variant="primary"
              href={platformCTA('charla-post')}
              label="Únete a VibeCoders"
            />
          </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
          <!-- Timestamps -->
          {timestamps.length > 0 && (
            <div class="mb-8">
              <h3 class="font-bold text-sm uppercase tracking-wider text-brand-black mb-4">
                Índice de contenido
              </h3>
              <ol class="space-y-2">
                {timestamps.map((ts) => (
                  <li class="flex items-start gap-3">
                    <span class="text-xs font-bold bg-brand-black text-brand-white px-2 py-0.5 shrink-0 font-mono rounded-none">
                      {formatSeconds(ts.seconds)}
                    </span>
                    <span class="text-sm" style="color: #888888;">{ts.label}</span>
                  </li>
                ))}
              </ol>
            </div>
          )}

          <!-- Resources -->
          {resources.length > 0 && (
            <div class="mb-10">
              <h3 class="font-bold text-sm uppercase tracking-wider text-brand-black mb-4">
                Recursos
              </h3>
              <ul class="space-y-3">
                {resources.map((resource) => (
                  <li>
                    <a
                      href={resource.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-center gap-2 text-sm text-brand-black hover:text-brand-blue transition-colors no-underline"
                    >
                      <span aria-hidden="true" set:html={resourceIconMap[resource.type] ?? resourceIconMap.other} />
                      <span class="font-bold">{resource.label}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Notes -->
          {notesHtml && (
            <div>
              <h3 class="font-bold text-sm uppercase tracking-wider text-brand-black mb-4">
                Notas
              </h3>
              <div class="prose prose-sm max-w-none text-brand-black prose-a:text-brand-blue prose-a:font-bold prose-headings:font-bold" set:html={notesHtml} />
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
