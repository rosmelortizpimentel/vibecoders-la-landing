---
import DirectoryLayout from '@/layouts/DirectoryLayout.astro';
import BuilderDirectoryCard from '@/components/directory/BuilderDirectoryCard.astro';
import { fetchDirectoryBuilders } from '@/lib/public-data';
import type { AllBuilder } from '@/types/all-builders';

const limit = 20;

let builders: AllBuilder[] = [];

try {
  builders = await fetchDirectoryBuilders(limit, 0);
} catch (error) {
  console.error('Failed to fetch builders:', error instanceof Error ? error.message : error);
}
const hasMore = builders.length === limit;

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Builders' },
];
---

<DirectoryLayout
  title="Builders"
  description="Conoce a los builders hispanohablantes que construyen productos digitales con IA."
  breadcrumbs={breadcrumbs}
>
  <!-- Grid -->
  <div id="builders-container" class="flex flex-col gap-6">
    {builders.map((builder) => (
      <BuilderDirectoryCard {...builder} />
    ))}
  </div>

  <!-- Empty state -->
  {builders.length === 0 && (
    <p class="text-center text-text-muted py-12">No hay builders aún.</p>
  )}

  <!-- Load more -->
  {hasMore && (
    <div class="flex justify-center mt-12">
      <button
        id="load-more-btn"
        data-offset={limit}
        class="bg-brand-black text-brand-white px-6 py-3 font-bold text-sm hover:opacity-70 transition-opacity cursor-pointer border border-brand-black"
      >
        Cargar más builders
      </button>
    </div>
  )}

  <script is:inline>
    const btn = document.getElementById('load-more-btn');
    const container = document.getElementById('builders-container');

    if (btn && container) {
      btn.addEventListener('click', async () => {
        const offset = parseInt(btn.getAttribute('data-offset'), 10);
        btn.textContent = 'Cargando...';
        btn.disabled = true;

        try {
          const res = await fetch(`/api/builders?offset=${offset}`);
          if (!res.ok) throw new Error('Error al cargar');
          const html = await res.text();
          
          if (html.trim() !== '') {
            container.insertAdjacentHTML('beforeend', html);
            
            // Check if end reached (via the injected marker from API)
            const endMarker = document.getElementById('end-of-builders');
            if (endMarker) {
              btn.remove();
              endMarker.remove(); // clean up
            } else {
              btn.setAttribute('data-offset', offset + limit);
              btn.textContent = 'Cargar más builders';
              btn.disabled = false;
            }
          } else {
            btn.remove();
          }
        } catch (e) {
          console.error(e);
          btn.textContent = 'Cargar más builders';
          btn.disabled = false;
        }
      });
    }
  </script>
</DirectoryLayout>
