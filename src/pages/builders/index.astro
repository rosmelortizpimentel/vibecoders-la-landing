---
import DirectoryLayout from '@/layouts/DirectoryLayout.astro';
import BuilderDirectoryCard from '@/components/directory/BuilderDirectoryCard.astro';
import { supabase } from '@/lib/supabase';
import type { AllBuilder } from '@/types/all-builders';

// Fetch verified builders from Supabase (reusing the same RPC as landing)
const { data: buildersData, error } = await supabase.rpc('get_verified_founders');

if (error) {
  console.error('Failed to fetch builders:', error.message);
}

const builders = (buildersData ?? []) as AllBuilder[];

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Builders' },
];
---

<DirectoryLayout
  title="Builders"
  description="Conoce a los builders hispanohablantes que construyen productos digitales con IA."
  breadcrumbs={breadcrumbs}
>
  <!-- Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {builders.map((builder) => (
      <BuilderDirectoryCard {...builder} />
    ))}
  </div>

  <!-- Empty state -->
  {builders.length === 0 && (
    <p class="text-center text-text-muted py-12">No hay builders aún.</p>
  )}
</DirectoryLayout>
