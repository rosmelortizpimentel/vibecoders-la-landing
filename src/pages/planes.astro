---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/directory/Breadcrumbs.astro';
import PricingTable from '@/components/pricing/PricingTable.astro';
import FAQSection from '@/components/pricing/FAQSection.astro';
import CTAButton from '@/components/ui/CTAButton.astro';
import { platformCTA } from '@/lib/urls';

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Planes' },
];
---

<BaseLayout
  title="Planes y precios | VibeCoders"
  description="VibeCoders es gratuito para siempre. El plan Pro desbloquea funciones avanzadas para builders que quieren ir más lejos."
>
  <!-- Breadcrumbs -->
  <div class="bg-brand-white max-w-[1440px] mx-auto px-6 pt-6">
    <Breadcrumbs items={breadcrumbs} />
  </div>

  <!-- Dark Hero -->
  <section class="bg-brand-black py-12 md:py-20">
    <div class="max-w-[800px] mx-auto px-6 text-center">
      <h1 class="font-bold text-[40px] md:text-[64px] leading-[0.95] text-brand-white mb-6">
        Planes y precios
      </h1>
      <p class="text-base md:text-lg leading-relaxed" style="color: #D9D9D6;">
        VibeCoders es gratuito para siempre. El plan Pro es para builders que quieren destacar, acceder antes y conectar más profundamente con la comunidad.
      </p>
    </div>
  </section>

  <!-- Light Content: Pricing Table -->
  <section class="bg-brand-white py-16">
    <div class="max-w-[900px] mx-auto px-6">
      <PricingTable />
    </div>
  </section>

  <!-- Dark Section: FAQ -->
  <section class="bg-brand-black py-16">
    <div class="max-w-[800px] mx-auto px-6">
      <h2 class="font-bold text-[28px] md:text-[40px] leading-[0.95] text-brand-white mb-12">
        Preguntas frecuentes
      </h2>
      <FAQSection />
    </div>
  </section>

  <!-- Light Section: Final CTA -->
  <section class="bg-brand-white py-16">
    <div class="max-w-[800px] mx-auto px-6 text-center">
      <h2 class="font-bold text-[28px] md:text-[40px] leading-[0.95] text-brand-black mb-4">
        Empieza hoy, gratis
      </h2>
      <p class="text-base leading-relaxed mb-8" style="color: #444444;">
        Crea tu perfil de builder, publica tus apps y conecta con la comunidad. Sin tarjeta de crédito.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <CTAButton
          variant="ghost"
          href={platformCTA('planes-free')}
          label="Empezar gratis"
        />
        <CTAButton
          variant="super-primary"
          href={platformCTA('planes-pro', '/choose-plan')}
          label="Ser Pro — $29.90/año"
        />
      </div>
    </div>
  </section>
</BaseLayout>
