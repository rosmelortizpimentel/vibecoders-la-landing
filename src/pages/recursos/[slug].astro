---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/directory/Breadcrumbs.astro';
import CTAButton from '@/components/ui/CTAButton.astro';
import { platformCTA } from '@/lib/urls';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const recursos = await getCollection('recursos', ({ data }) => data.draft !== true);
  return recursos.map((recurso) => ({
    params: { slug: recurso.id },
    props: { recurso },
  }));
}

const { recurso } = Astro.props;
const { Content } = await render(recurso);

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Recursos', href: '/recursos' },
  { label: recurso.data.title },
];

const typeLabel: Record<string, string> = {
  prompt: 'Prompt',
  template: 'Plantilla',
  guide: 'Guía',
  snippet: 'Snippet',
  spec: 'Spec',
};

const difficultyLabel: Record<string, string> = {
  beginner: 'Principiante',
  intermediate: 'Intermedio',
  advanced: 'Avanzado',
};
---

<BaseLayout
  title={`${recurso.data.title} | Recursos | VibeCoders`}
  description={recurso.data.description}
>
  <!-- Breadcrumbs -->
  <div class="bg-brand-white max-w-[1440px] mx-auto px-6 pt-6">
    <Breadcrumbs items={breadcrumbs} />
  </div>

  <!-- Dark Hero -->
  <section class="bg-brand-black py-12 md:py-20">
    <div class="max-w-[800px] mx-auto px-6">
      <!-- Badges -->
      <div class="flex flex-wrap gap-2 mb-6">
        <span class="text-xs font-bold uppercase tracking-wider px-2 py-0.5 bg-surface-charcoal text-brand-white rounded-none">
          {typeLabel[recurso.data.type] ?? recurso.data.type}
        </span>
        <span class="text-xs font-bold uppercase tracking-wider px-2 py-0.5 bg-surface-charcoal text-brand-white rounded-none">
          {difficultyLabel[recurso.data.difficulty] ?? recurso.data.difficulty}
        </span>
      </div>

      <!-- Title -->
      <h1 class="font-bold text-[32px] md:text-[48px] leading-[0.95] text-brand-white mb-6">
        {recurso.data.title}
      </h1>

      <!-- Description -->
      <p class="text-base md:text-lg leading-relaxed" style="color: #D9D9D6;">
        {recurso.data.description}
      </p>

      <!-- Compatible tools -->
      {recurso.data.compatibleTools.length > 0 && (
        <div class="mt-6 pt-6 border-t border-surface-charcoal">
          <p class="text-xs font-bold uppercase tracking-wider mb-3" style="color: #888888;">Compatible con</p>
          <div class="flex flex-wrap gap-2">
            {recurso.data.compatibleTools.map((toolSlug) => (
              <a
                href={`/tools/${toolSlug}`}
                class="text-xs font-bold px-3 py-1 bg-surface-charcoal text-brand-white hover:bg-brand-white hover:text-brand-black transition-colors no-underline"
              >
                {toolSlug}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Light Content -->
  <section class="bg-brand-white py-12">
    <div class="max-w-[800px] mx-auto px-6">
      <!-- Download CTA if available -->
      {recurso.data.downloadUrl && (
        <div class="mb-10 p-6 bg-surface-silver flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
          <div>
            <p class="font-bold text-brand-black text-sm">Descarga este recurso</p>
            <p class="text-xs mt-1" style="color: #888888;">Disponible para descarga inmediata</p>
          </div>
          <CTAButton
            variant="primary"
            href={recurso.data.downloadUrl}
            label="Descargar"
          />
        </div>
      )}

      <!-- MDX content -->
      <article class="prose prose-lg max-w-none prose-headings:text-brand-black prose-headings:font-bold prose-a:text-brand-blue prose-a:no-underline hover:prose-a:underline prose-strong:text-brand-black prose-code:bg-surface-silver prose-code:text-brand-black prose-code:rounded-none prose-pre:rounded-none prose-blockquote:border-l-brand-black prose-pre:bg-surface-silver">
        <Content />
      </article>

      <!-- Tags -->
      {recurso.data.tags.length > 0 && (
        <div class="mt-10 pt-6 border-t border-border">
          <div class="flex flex-wrap gap-2">
            {recurso.data.tags.map((tag) => (
              <span class="text-xs font-bold uppercase tracking-wider px-2 py-0.5 bg-surface-silver text-brand-black rounded-none">
                {tag}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- CTA -->
      <div class="mt-12 pt-8 border-t border-border text-center">
        <p class="text-sm font-bold text-brand-black mb-4 uppercase tracking-wider">
          ¿Quieres acceder a más recursos como este?
        </p>
        <CTAButton
          variant="primary"
          href={platformCTA('recurso')}
          label="Únete a VibeCoders"
        />
      </div>
    </div>
  </section>
</BaseLayout>
