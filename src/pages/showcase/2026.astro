---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/directory/Breadcrumbs.astro';
import CTAButton from '@/components/ui/CTAButton.astro';
import { platformCTA } from '@/lib/urls';

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Showcase' },
  { label: '2026' },
];

// A small teaser list — just names, no elaborate data
const teaser = [
  'CalendarioIA',
  'BuildTracker',
  'PromptBox',
];
---

<BaseLayout
  title="Lo mejor de 2026 | Showcase | VibeCoders"
  description="Las mejores aplicaciones construidas por la comunidad VibeCoders en 2026."
>
  <!-- Breadcrumbs -->
  <div class="bg-brand-white max-w-[1440px] mx-auto px-6 pt-6">
    <Breadcrumbs items={breadcrumbs} />
  </div>

  <!-- Dark Hero -->
  <section class="bg-brand-black py-12 md:py-20">
    <div class="max-w-[800px] mx-auto px-6">
      <span class="text-xs font-bold uppercase tracking-wider px-2 py-0.5 bg-surface-charcoal text-brand-white rounded-none mb-6 inline-block">
        Showcase 2026
      </span>
      <h1 class="font-bold text-[40px] md:text-[64px] leading-[0.95] text-brand-white mb-6">
        Lo mejor de 2026
      </h1>
      <p class="text-base md:text-lg leading-relaxed" style="color: #D9D9D6;">
        Las aplicaciones más destacadas construidas por la comunidad VibeCoders durante el año.
      </p>
    </div>
  </section>

  <!-- Light Content -->
  <section class="bg-brand-white py-16">
    <div class="max-w-[800px] mx-auto px-6 text-center">
      <div class="bg-surface-silver p-12 mb-10">
        <p class="font-bold text-[24px] text-brand-black mb-3">Próximamente</p>
        <p class="text-sm leading-relaxed" style="color: #888888;">
          El showcase de 2026 se publicará al cierre del año. Aquí aparecerán las mejores apps votadas por la comunidad.
        </p>
      </div>

      <!-- Teaser -->
      <p class="text-xs font-bold uppercase tracking-wider mb-4" style="color: #888888;">
        Algunos proyectos que ya están en camino
      </p>
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        {teaser.map((name) => (
          <span class="text-sm font-bold px-4 py-2 bg-brand-black text-brand-white">
            {name}
          </span>
        ))}
      </div>

      <CTAButton
        variant="primary"
        href={platformCTA('showcase-2026')}
        label="Publicar mi app"
      />
    </div>
  </section>
</BaseLayout>
