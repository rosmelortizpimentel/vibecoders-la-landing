---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/directory/Breadcrumbs.astro';
import CTAButton from '@/components/ui/CTAButton.astro';
import { platformCTA } from '@/lib/urls';

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Construido en público' },
];
---

<BaseLayout
  title="Construido en público | VibeCoders"
  description="Un feed en tiempo real de lo que la comunidad VibeCoders está construyendo."
>
  <!-- Breadcrumbs -->
  <div class="bg-brand-white max-w-[1440px] mx-auto px-6 pt-6">
    <Breadcrumbs items={breadcrumbs} />
  </div>

  <!-- Dark Hero -->
  <section class="bg-brand-black py-12 md:py-20">
    <div class="max-w-[800px] mx-auto px-6">
      <h1 class="font-bold text-[40px] md:text-[64px] leading-[0.95] text-brand-white mb-6">
        Construido en público
      </h1>
      <p class="text-base md:text-lg leading-relaxed" style="color: #D9D9D6;">
        Un feed en tiempo real de lo que la comunidad está construyendo.
      </p>
    </div>
  </section>

  <!-- Light Content -->
  <section class="bg-brand-white py-16">
    <div class="max-w-[800px] mx-auto px-6 text-center">
      <div class="bg-surface-silver p-12 mb-10">
        <p class="font-bold text-[24px] text-brand-black mb-3">Próximamente</p>
        <p class="text-sm leading-relaxed" style="color: #888888;">
          Un feed en tiempo real con los avances, lanzamientos y aprendizajes que los builders de la comunidad comparten a medida que construyen. Disponible en la próxima fase.
        </p>
      </div>
      <CTAButton
        variant="primary"
        href={platformCTA('construido-en-publico')}
        label="Unirse a la comunidad"
      />
    </div>
  </section>
</BaseLayout>
