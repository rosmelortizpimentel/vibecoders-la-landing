---
export const prerender = false;

import AppDirectoryCard from '@/components/directory/AppDirectoryCard.astro';
import { fetchDirectoryApps } from '@/lib/public-data';
import type { ShowcaseApp } from '@/types/showcase-app';

const limit = 20;
const offset = parseInt(Astro.url.searchParams.get('offset') || '0', 10);

let apps: ShowcaseApp[] = [];

try {
  apps = await fetchDirectoryApps(limit, offset);
} catch (error) {
  console.error('Failed to fetch apps:', error instanceof Error ? error.message : error);
}

const hasMore = apps.length === limit;
---

{apps.map((app) => (
  <AppDirectoryCard {...app} />
))}

{!hasMore && <div id="end-of-apps" class="hidden"></div>}
