---
import DirectoryLayout from '@/layouts/DirectoryLayout.astro';
import Badge from '@/components/ui/Badge.astro';
import CTAButton from '@/components/ui/CTAButton.astro';
import RelatedTerms from '@/components/editorial/RelatedTerms.astro';
import { getCollection, render } from 'astro:content';
import { platformCTA } from '@/lib/urls';

export async function getStaticPaths() {
  const terms = await getCollection('glosario', ({ data }) => data.draft !== true);
  return terms.map((term) => ({
    params: { slug: term.id },
    props: { term },
  }));
}

const { term } = Astro.props;
const { Content } = await render(term);

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Glosario', href: '/glosario' },
  { label: term.data.term },
];
---

<DirectoryLayout
  title={term.data.term}
  description={term.data.shortDefinition}
  breadcrumbs={breadcrumbs}
>
  <!-- Term header -->
  <div class="mb-8 pb-8 border-b border-border">
    <div class="flex flex-wrap items-center gap-3 mb-4">
      <h1 class="font-bold text-[32px] md:text-[48px] leading-[0.95] text-brand-black">
        {term.data.term}
        {term.data.acronym && (
          <span class="text-xl md:text-2xl font-normal ml-2" style="color: #888888;">
            ({term.data.acronym})
          </span>
        )}
      </h1>
    </div>
    <Badge variant="category" value={term.data.category} />
    <p class="text-base leading-relaxed mt-4 max-w-prose" style="color: #888888;">
      {term.data.shortDefinition}
    </p>
  </div>

  <!-- MDX content -->
  <div class="max-w-prose">
    <article class="prose prose-lg max-w-none prose-headings:text-brand-black prose-headings:font-bold prose-a:text-brand-blue prose-a:no-underline hover:prose-a:underline prose-strong:text-brand-black prose-code:bg-surface-silver prose-code:text-brand-black prose-code:rounded-none prose-pre:rounded-none">
      <Content />
    </article>

    <!-- Related terms -->
    {term.data.relatedTerms && term.data.relatedTerms.length > 0 && (
      <RelatedTerms terms={term.data.relatedTerms} currentSlug={term.id} />
    )}

    <!-- CTA -->
    <div class="mt-12 pt-8 border-t border-border">
      <p class="text-sm font-bold text-brand-black mb-4 uppercase tracking-wider">
        ¿Quieres profundizar en estos conceptos con la comunidad?
      </p>
      <CTAButton
        variant="ghost"
        href={platformCTA('glosario-term')}
        label="Únete a VibeCoders"
      />
    </div>
  </div>
</DirectoryLayout>
