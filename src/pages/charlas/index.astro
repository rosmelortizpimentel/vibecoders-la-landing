---
import DirectoryLayout from '@/layouts/DirectoryLayout.astro';
import PublicCharlaCard from '@/components/editorial/PublicCharlaCard.astro';
import { supabase } from '@/lib/supabase';
import type { LandingCharla } from '@/types/landing-charla';

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Charlas' },
];

const { data, error } = await supabase.rpc('get_public_charlas');

if (error) {
  console.error('Failed to fetch public charlas:', error.message);
}

const charlas = (data ?? []) as LandingCharla[];
---

<DirectoryLayout
  title="Charlas en vivo"
  description="Sesiones en vivo con builders, founders y expertos del ecosistema Vibe Coding. Aprende de quienes ya construyeron lo que tú quieres construir."
  breadcrumbs={breadcrumbs}
>
  {charlas.length === 0 ? (
    <div class="bg-surface-silver p-12 text-center">
      <p class="text-sm" style="color: #888888;">Próximamente: sesiones en vivo con la comunidad.</p>
    </div>
  ) : (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {charlas.map((charla) => (
        <PublicCharlaCard charla={charla} />
      ))}
    </div>
  )}
</DirectoryLayout>
