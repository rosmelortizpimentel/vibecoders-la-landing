---
import DirectoryLayout from '@/layouts/DirectoryLayout.astro';
import AppDirectoryCard from '@/components/directory/AppDirectoryCard.astro';
import FilterBar from '@/components/directory/FilterBar.astro';
import { supabase } from '@/lib/supabase';
import type { ShowcaseApp } from '@/types/showcase-app';

// Fetch showcase apps from Supabase RPC
const { data: appsData, error } = await supabase.rpc('get_showcase_apps');

if (error) {
  console.error('Failed to fetch showcase apps:', error.message);
}

const apps = (appsData ?? []) as ShowcaseApp[];

// Build filter pills from data
const filters = [
  { label: 'Open for Testing', value: 'open-testing' },
  { label: 'Open to Partnerships', value: 'open-partnerships' }
];

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Apps' },
];
---

<DirectoryLayout
  title="Apps"
  description="Explorá los productos digitales construidos por la comunidad VibeCoders con IA."
  breadcrumbs={breadcrumbs}
>
  <!-- Filter bar -->
  <div class="mb-8">
    <FilterBar filters={filters} />
  </div>

  <!-- Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {apps.map((app) => (
      <AppDirectoryCard {...app} />
    ))}
  </div>
</DirectoryLayout>