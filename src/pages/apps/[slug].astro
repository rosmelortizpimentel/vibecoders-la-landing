---
// Disable static generation - this page is SSR
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Badge from '@/components/ui/Badge.astro';
import Breadcrumbs from '@/components/directory/Breadcrumbs.astro';
import SpeakerCard from '@/components/editorial/SpeakerCard.astro';
import { platformCTA } from '@/lib/urls';

// The route param is 'slug' but we're passing the app ID
const appIdParam = Astro.params.slug || '';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

// Fetch app detail from edge function
const edgeFunctionUrl = `${supabaseUrl}/functions/v1/get-app-detail?app_id=${encodeURIComponent(appIdParam)}`;
const response = await fetch(edgeFunctionUrl, {
  headers: {
    'Authorization': `Bearer ${supabaseAnonKey}`,
    'apikey': supabaseAnonKey,
  },
});

let appData;
try {
  appData = await response.json();
} catch (e) {
  console.error('Failed to parse response:', e);
}

if (!response.ok || !appData?.id) {
  return Astro.redirect('/apps');
}

console.log('Checking redirect condition:', !response.ok, !appData?.id);

console.log('Checking redirect condition:', !response.ok, !appData?.id);

if (!response.ok || !appData?.id) {
  console.error('Redirecting due to:', response.status, appData);
  return Astro.redirect('/apps');
}

const app = appData;

// App detail fields that need to be filled with dummy data
const hasLikesCount = typeof app.likes_count === 'number';
const hasTestersCount = typeof app.testers_count === 'number';
const hasScreenshots = app.screenshots && app.screenshots.length > 0;

// Dummy data for missing fields
const metrics = {
  likes: hasLikesCount ? app.likes_count : 42,
  clicks: 128,
  views: 345,
};

const testers = hasTestersCount ? app.testers_count : 3;

const initial = app.name.charAt(0).toUpperCase();

const builderUrl = platformCTA('app-detail-builder', `/@${app.owner?.username}`);

const betaCta = 'https://app.vibecoders.la/public-beta-testing';

const uniqueFounders = Array.isArray(app.founders)
  ? app.founders.filter((founder: any, index: number, founders: any[]) => {
      const founderId = founder.user_id ?? founder.profile?.id ?? founder.profile?.username;
      return founders.findIndex((candidate: any) => {
        const candidateId = candidate.user_id ?? candidate.profile?.id ?? candidate.profile?.username;
        return candidateId === founderId;
      }) === index;
    })
  : [];
---

<BaseLayout title={`${app.name} | Apps | VibeCoders`} description={app.tagline ?? undefined}>
  <!-- Breadcrumbs -->
  <div class="bg-brand-white max-w-[1440px] mx-auto px-6 pt-6">
    <Breadcrumbs items={[
      { label: 'Inicio', href: '/' },
      { label: 'Apps', href: '/apps' },
      { label: app.name },
    ]} />
  </div>

  <!-- Hero Section -->
  <section class="bg-brand-black py-12 md:py-16">
    <div class="max-w-[1440px] mx-auto px-6">
      <div class="flex flex-col lg:flex-row gap-8 lg:items-start">
        <!-- Logo + Basic Info -->
        <div class="flex flex-col gap-6 lg:w-1/3">
          <div class="w-24 h-24 lg:w-32 lg:h-32 bg-surface-charcoal flex items-center justify-center">
            {app.logo_url ? (
              <img src={app.logo_url} alt={app.name} class="w-full h-full object-contain" />
            ) : (
              <span class="text-brand-white font-bold text-5xl">{initial}</span>
            )}
          </div>

          <div>
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <h1 class="text-4xl lg:text-5xl font-bold text-brand-white leading-tight">
                {app.name}
              </h1>
              {app.is_verified && (
                <span class="text-xs font-bold text-brand-yellow uppercase tracking-wider">Verified</span>
              )}
            </div>
            <p class="text-lg text-brand-white mb-4">{app.tagline ?? ''}</p>
            <div class="flex flex-wrap gap-2 mb-6">
              {app.category && (
                <Badge variant="category" value={app.category.name} />
              )}
              {app.status?.name && (
                <Badge variant="status" value={app.status.name} />
              )}
            </div>
          </div>

          <!-- CTA Buttons -->
          <div class="flex flex-wrap gap-4">
            <a
              href={app.url}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-brand-yellow text-brand-black px-6 py-3 font-bold text-sm hover:opacity-70 transition-opacity no-underline"
            >
              Visitar App
            </a>
            {app.beta_active && (
              <a
                href={betaCta}
                target="_blank"
                rel="noopener noreferrer"
                class="bg-surface-charcoal text-brand-white px-6 py-3 font-bold text-sm hover:opacity-70 transition-opacity no-underline"
              >
                Unirse a Beta
              </a>
            )}
          </div>

          <!-- Stats -->
          <div class="flex items-center gap-6 pt-4 border-t border-surface-charcoal">
            <div class="text-center">
              <p class="text-xl font-bold text-brand-white">{metrics.likes}</p>
              <p class="text-xs" style="color: #888888;">Likes</p>
            </div>
            <div class="text-center">
              <p class="text-xl font-bold text-brand-white">{metrics.clicks}</p>
              <p class="text-xs" style="color: #888888;">Clicks</p>
            </div>
            {testers > 0 && (
              <div class="text-center">
                <p class="text-xl font-bold text-brand-white">{testers}</p>
                <p class="text-xs" style="color: #888888;">Testers</p>
              </div>
            )}
          </div>
        </div>

        <!-- Builder Info + Description -->
        <div class="lg:w-2/3">
          <!-- Builder cards -->
          {uniqueFounders.length > 0 ? (
            <div class="flex flex-col gap-4 mb-6">
              <h2 class="font-bold text-lg text-brand-white">Builders</h2>
              {uniqueFounders.map((founder: any) => (
                <div class="bg-surface-charcoal p-6">
                  <SpeakerCard
                    speaker={{
                      name: founder.profile?.name || 'Builder anónimo',
                      username: founder.profile?.username,
                      role: founder.profile?.tagline || founder.role || 'Builder',
                      bio: '', // Not shown here, tagline acts as role
                      avatarUrl: founder.profile?.avatar_url,
                      linkedinUrl: founder.profile?.linkedin,
                      twitterUrl: founder.profile?.twitter,
                      githubUrl: founder.profile?.github,
                      youtubeUrl: founder.profile?.youtube,
                      websiteUrl: founder.profile?.website,
                      lovableUrl: founder.profile?.lovable
                    }}
                    onDark={true}
                    showBio={false}
                  />
                </div>
              ))}
            </div>
          ) : (
            <a href={builderUrl} class="block bg-surface-charcoal p-6 mb-6 hover:opacity-80 transition-opacity no-underline">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full overflow-hidden bg-brand-black flex items-center justify-center">
                  {app.owner?.avatar_url ? (
                    <img src={app.owner.avatar_url} alt={app.owner.name} class="w-full h-full object-cover" />
                  ) : (
                    <span class="text-brand-white font-bold">{app.owner?.name?.charAt(0) || '?'}</span>
                  )}
                </div>
                <div>
                  <p class="font-bold text-brand-white">{app.owner?.name}</p>
                  <p class="text-sm" style="color: #888888;">@{app.owner?.username}</p>
                </div>
              </div>
            </a>
          )}

          <!-- Description -->
          {app.description && (
            <div class="mb-6">
              <h2 class="font-bold text-xl text-brand-white mb-3">Acerca de esta app</h2>
              <p class="text-sm leading-relaxed" style="color: #D9D9D6;">{app.description}</p>
            </div>
          )}

          <!-- Tags -->
          {app.tags && app.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {app.tags.map((tag: string) => (
                <span class="text-xs px-3 py-1 bg-surface-charcoal text-brand-white">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Screenshots -->
  {hasScreenshots && (
    <section class="bg-brand-black py-12">
      <div class="max-w-[1440px] mx-auto px-6">
        <h2 class="font-bold text-xl text-brand-white mb-6">Capturas de pantalla</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {app.screenshots.map((screenshot: string) => (
            <div class="bg-surface-charcoal overflow-hidden rounded-none">
              <img
                src={screenshot}
                alt=""
                class="w-full h-auto max-h-[300px] object-contain"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Tech Stack -->
  {app.stacks && app.stacks.length > 0 && (
    <section class="bg-brand-black py-12">
      <div class="max-w-[1440px] mx-auto px-6">
        <h2 class="font-bold text-xl text-brand-white mb-6">Stack tecnológico</h2>
        <div class="flex flex-wrap gap-4">
          {app.stacks.map((stack: any) => (
            <div class="flex items-center gap-2 bg-surface-charcoal px-4 py-2">
              {stack.logo_url ? (
                <img src={stack.logo_url} alt={stack.name} class="w-5 h-5" />
              ) : (
                <span class="w-5 h-5 bg-brand-black" />
              )}
              <span class="text-sm text-brand-white">{stack.name}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Testers (dummy data for now) -->
  {testers > 0 && (
    <section class="bg-brand-white py-12">
      <div class="max-w-[1440px] mx-auto px-6">
        <h2 class="font-bold text-xl text-brand-black mb-6">Testers ({testers})</h2>
        <p class="text-sm" style="color: #888888;">Únete a la beta para convertirte en tester.</p>
      </div>
    </section>
  )}

  <!-- Partnership (dummy data for now) -->
  {app.open_to_partnerships && (
    <section class="bg-brand-white py-12">
      <div class="max-w-[1440px] mx-auto px-6">
        <h2 class="font-bold text-xl text-brand-black mb-4">Colaboraciones</h2>
        <p class="text-sm" style="color: #888888;">
          Esta app está abierta a colaboraciones. Contacta al builder.
        </p>
      </div>
    </section>
  )}
</BaseLayout>
