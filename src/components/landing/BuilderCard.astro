---
import type { VerifiedFounder } from '@/types/verified-founder';
import Badge from '@/components/ui/Badge.astro';
import SocialLinks from '@/components/ui/SocialLinks.astro';

type Props = Pick<VerifiedFounder, 'display_name' | 'avatar_url' | 'tagline' | 'city' | 'is_pro' | 'is_founder' | 'social_links'>;

const { display_name, avatar_url, tagline, city, is_pro, is_founder, social_links } = Astro.props;

// Generate initial for avatar fallback
const initial = display_name.charAt(0).toUpperCase();

function formatLocation(rawCity?: string | null) {
  if (!rawCity) return null;

  const normalized = rawCity.toLowerCase();
  const countryCodeMap: Record<string, string> = {
    argentina: 'AR',
    españa: 'ES',
    spain: 'ES',
    colombia: 'CO',
    perú: 'PE',
    peru: 'PE',
    méxico: 'MX',
    mexico: 'MX',
    chile: 'CL',
    uruguay: 'UY',
    bolivia: 'BO',
    ecuador: 'EC',
    paraguay: 'PY',
    venezuela: 'VE',
    guatemala: 'GT',
    honduras: 'HN',
    panamá: 'PA',
    panama: 'PA',
    'república dominicana': 'DO',
    'republica dominicana': 'DO',
  };

  const countryCode = Object.entries(countryCodeMap).find(([country]) => normalized.includes(country))?.[1];
  const cityLabel = rawCity
    .split(',')[0]
    ?.trim()
    ?.toUpperCase();

  return countryCode ? `${cityLabel} · ${countryCode}` : cityLabel;
}

const locationLabel = formatLocation(city);
---

<div class="w-[520px] h-full min-h-[180px] p-8 bg-brand-white border border-brand-black flex gap-6 shrink-0 flex-1">
  <div class="w-20 h-20 rounded-full overflow-hidden bg-[#3D5AFE] flex items-center justify-center shrink-0 mt-1">
    {avatar_url ? (
      <img
        src={avatar_url}
        alt={display_name}
        width="80"
        height="80"
        class="w-full h-full object-cover"
        loading="lazy"
      />
    ) : (
      <span class="text-brand-white font-bold text-xl">{initial}</span>
    )}
  </div>

  <div class="flex-1 min-w-0 flex flex-col gap-4">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0">
        <p class="text-[20px] font-bold text-brand-black leading-tight truncate">{display_name}</p>
        {locationLabel && (
          <p class="text-[13px] tracking-[0.22em] uppercase text-brand-black/70 mt-2 truncate">{locationLabel}</p>
        )}
      </div>
      <div class="flex items-center gap-3 shrink-0">
        {is_founder && (
          <Badge variant="tier" value="BUILDER FUNDADOR" />
        )}
        {is_pro && (
          <Badge variant="tier" value="PRO" />
        )}
      </div>
    </div>

    {tagline && (
      <p class={`text-[16px] text-brand-black leading-relaxed line-clamp-2 ${!social_links || Object.keys(social_links).length === 0 ? 'mt-auto' : ''}`}>
        {tagline}
      </p>
    )}

    {social_links && Object.keys(social_links).length > 0 && (
      <div class="mt-auto pt-4 border-t border-brand-black/10">
        <SocialLinks socials={social_links} class="text-brand-black" />
      </div>
    )}
  </div>
</div>
