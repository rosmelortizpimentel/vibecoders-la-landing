---
import type { VerifiedFounder } from '@/types/verified-founder';

type Props = Pick<VerifiedFounder, 'display_name' | 'avatar_url' | 'tagline' | 'city' | 'is_pro' | 'is_founder'>;

const { display_name, avatar_url, tagline, city, is_pro, is_founder } = Astro.props;

// Generate initial for avatar fallback
const initial = display_name.charAt(0).toUpperCase();
---

<div class="w-[200px] h-[160px] p-3 bg-surface-silver flex flex-col gap-2 shrink-0">
  <!-- Avatar + badges row -->
  <div class="flex items-start justify-between">
    <div class="w-10 h-10 rounded-full overflow-hidden bg-surface-charcoal flex items-center justify-center shrink-0">
      {avatar_url ? (
        <img
          src={avatar_url}
          alt={display_name}
          width="40"
          height="40"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      ) : (
        <span class="text-brand-white font-bold text-xs">{initial}</span>
      )}
    </div>
    <div class="flex items-center gap-2">
      {is_founder && (
        <span
          title="Builder Fundador"
          aria-label="Builder Fundador"
          class="w-7 h-7 rounded-full bg-[#EFDF00] text-brand-black font-black text-[10px] flex items-center justify-center border border-brand-black"
        >
          BF
        </span>
      )}
      {is_pro && (
        <span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 bg-[#C9B458] text-brand-black inline-block border border-brand-black">
          Pro
        </span>
      )}
    </div>
  </div>

  <!-- Info -->
  <div class="flex-1 overflow-hidden">
    <p class="text-xs font-bold text-brand-black leading-tight truncate">{display_name}</p>
    {tagline && (
      <p class="text-[10px] text-text-muted mt-1 line-clamp-2 leading-relaxed" style="color: #888888;">
        {tagline}
      </p>
    )}
  </div>

  <!-- City -->
  {city && (
    <p class="text-[10px] text-text-muted truncate" style="color: #888888;">
      {city}
    </p>
  )}
</div>
