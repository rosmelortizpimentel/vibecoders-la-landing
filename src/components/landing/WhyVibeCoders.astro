---
import SectionWrapper from '@/components/landing/SectionWrapper.astro';

const valueBlocks = [
  {
    title: 'Perfil público de builder',
    description:
      'Crea tu perfil profesional, muestra tus apps y conecta con otros builders. Visible para toda la comunidad y para Google.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
      <circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
    </svg>`,
  },
  {
    title: 'Roadmap y feedback público',
    description:
      'Gestiona el roadmap de tu app de forma pública. Recibe feedback real de la comunidad y beta testers antes de lanzar.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"/>
    </svg>`,
  },
  {
    title: 'Charlas con builders reales',
    description:
      'Cada semana alguien de la comunidad comparte cómo construyó algo con IA. Sin PowerPoints corporativos. Solo experiencia directa.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"/>
    </svg>`,
  },
  {
    title: 'En español, para LATAM y España',
    description:
      'Todo el contenido, las charlas y los recursos están en español. Construido para el mercado hispanohablante.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
      <line x1="2" y1="12" x2="22" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
    </svg>`,
  },
];
---

<SectionWrapper variant="light" id="why">
  <!-- Heading -->
  <div class="text-center mb-12">
    <h2 class="text-[32px] md:text-[40px] font-bold leading-[0.95] text-brand-black">
      Qué puedes hacer en VibeCoders
    </h2>
    <p class="text-sm mt-3 max-w-lg mx-auto leading-relaxed" style="color: #888888;">
      No es otra comunidad de tech. Es la comunidad de los que construyen.
    </p>
  </div>

  <!-- 2x2 Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {valueBlocks.map((block) => (
      <div class="flex flex-col gap-4">
        <!-- Icon -->
        <div class="text-brand-black w-6 h-6" set:html={block.icon} />

        <!-- Heading -->
        <h3 class="text-[24px] font-bold leading-[0.95] text-brand-black">
          {block.title}
        </h3>

        <!-- Description -->
        <p class="text-sm leading-[1.4]" style="color: rgba(0,0,0,0.7);">
          {block.description}
        </p>
      </div>
    ))}
  </div>
</SectionWrapper>
