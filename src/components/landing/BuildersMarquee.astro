---
import SectionWrapper from '@/components/landing/SectionWrapper.astro';
import BuilderCard from '@/components/landing/BuilderCard.astro';
import CTAButton from '@/components/ui/CTAButton.astro';
import type { VerifiedFounder } from '@/types/verified-founder';

interface Props {
  builders: VerifiedFounder[];
}

const { builders } = Astro.props;
const duplicatedBuilders = [...builders, ...builders];
---

<SectionWrapper variant="light" id="builders">
  <!-- Heading -->
  <div class="text-center mb-10">
    <h2 class="text-[32px] md:text-[40px] font-bold leading-[0.95] text-brand-black">
      Los builders que construyen
    </h2>
    <p class="text-sm text-text-muted mt-3 max-w-lg mx-auto leading-relaxed" style="color: #888888;">
      Conoce a quienes lanzan productos reales con IA cada semana.
    </p>
  </div>

  <!-- Auto carousel -->
  <div class="relative">
    <button
      type="button"
      class="builders-prev absolute left-0 top-1/2 z-10 -translate-y-1/2 bg-brand-white border border-brand-black text-brand-black w-10 h-10 hidden md:flex items-center justify-center hover:bg-brand-black hover:text-brand-white transition-colors"
      aria-label="Ver builders anteriores"
    >
      ←
    </button>

    <div class="builders-carousel overflow-x-auto overflow-y-hidden pb-2 -mx-6 px-6 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
      <div class="builders-track flex flex-nowrap items-stretch gap-4 w-max">
        {duplicatedBuilders.map((builder, index) => (
          <a
            href={`/builders/${builder.username}`}
            class="flex flex-col no-underline hover:opacity-80 transition-opacity h-full"
            data-builder-card
            aria-hidden={index >= builders.length ? 'true' : 'false'}
            tabindex={index >= builders.length ? '-1' : undefined}
          >
            <BuilderCard
              display_name={builder.display_name}
              avatar_url={builder.avatar_url}
              tagline={builder.tagline}
              city={builder.city}
              is_pro={builder.is_pro}
              is_founder={builder.is_founder}
            />
          </a>
        ))}
      </div>
    </div>

    <button
      type="button"
      class="builders-next absolute right-0 top-1/2 z-10 -translate-y-1/2 bg-brand-white border border-brand-black text-brand-black w-10 h-10 hidden md:flex items-center justify-center hover:bg-brand-black hover:text-brand-white transition-colors"
      aria-label="Ver más builders"
    >
      →
    </button>
  </div>

  <script is:inline>
    (() => {
      const root = document.currentScript?.closest('section');
      if (!root) return;

      const carousel = root.querySelector('.builders-carousel');
      const track = root.querySelector('.builders-track');
      const prev = root.querySelector('.builders-prev');
      const next = root.querySelector('.builders-next');
      const firstCard = root.querySelector('[data-builder-card]');

      if (!carousel || !track || !firstCard) return;

      let paused = false;
      let rafId = 0;
      const speed = 0.35;
      const cycleWidth = track.scrollWidth / 2;
      const cardStep = firstCard.getBoundingClientRect().width + 16;

      const tick = () => {
        if (!paused) {
          carousel.scrollLeft += speed;
          if (carousel.scrollLeft >= cycleWidth) {
            carousel.scrollLeft -= cycleWidth;
          }
        }
        rafId = window.requestAnimationFrame(tick);
      };

      const moveBy = (amount) => {
        paused = true;
        carousel.scrollBy({ left: amount, behavior: 'smooth' });
      };

      root.addEventListener('mouseenter', () => {
        paused = true;
      });

      root.addEventListener('mouseleave', () => {
        paused = false;
      });

      prev?.addEventListener('click', () => moveBy(-cardStep * 2));
      next?.addEventListener('click', () => moveBy(cardStep * 2));

      rafId = window.requestAnimationFrame(tick);

      window.addEventListener(
        'beforeunload',
        () => {
          window.cancelAnimationFrame(rafId);
        },
        { once: true }
      );
    })();
  </script>

  <!-- CTA -->
  <div class="flex justify-center mt-10">
    <CTAButton
      href="/builders"
      variant="ghost"
      onDark={false}
      label="Ver todos los builders"
    />
  </div>
</SectionWrapper>
