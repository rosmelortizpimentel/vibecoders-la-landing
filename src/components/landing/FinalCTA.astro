---
import SectionWrapper from '@/components/landing/SectionWrapper.astro';
import CTAButton from '@/components/ui/CTAButton.astro';

interface Props {
  href: string;
}

const { href } = Astro.props;
---

<SectionWrapper variant="dark" id="final-cta" padding="generous">
  <div class="text-center max-w-2xl mx-auto">
    <!-- H2 -->
    <h2
      class="text-[32px] md:text-[40px] font-bold leading-[0.95] text-brand-white mb-6"
    >
      Nadie escala solo.
    </h2>

    <!-- Subtitle -->
    <p class="text-sm text-text-muted mb-10 max-w-lg mx-auto leading-relaxed">
      Únete a más de 100 builders construyendo en público con herramientas de IA.
      Tu próximo producto empieza aquí.
    </p>

    <!-- Super-primary yellow CTA -->
    <CTAButton
      href={href}
      variant="super-primary"
      label="Unirme a la comunidad →"
    />
  </div>
</SectionWrapper>
