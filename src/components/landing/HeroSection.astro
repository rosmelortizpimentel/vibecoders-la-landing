---
import CTAButton from '@/components/ui/CTAButton.astro';

interface Props {
  heroCTA: string;
}

const { heroCTA } = Astro.props;

---

<section class="bg-brand-black min-h-screen flex items-center px-8 md:px-12 lg:px-16 py-12 md:py-20 overflow-hidden relative">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute inset-y-0 right-0 w-full md:w-1/2 lg:w-[48%] flex items-center justify-end pr-6 md:pr-10 lg:pr-16">
      <img
        src="/images/hero/vibecoder-sheep-laptop.png"
        alt=""
        aria-hidden="true"
        class="w-[400px] max-w-[76vw] md:w-[500px] lg:w-[620px] opacity-25 md:opacity-40 object-contain object-right"
      />
    </div>
  </div>

  <div class="max-w-[1440px] mx-auto w-full relative z-10">
    <div class="max-w-4xl text-center md:text-left">
      <!-- H1 -->
      <h1
        class="font-bold leading-[0.95] text-brand-white
               text-[32px] sm:text-[40px] md:text-[56px]
               mb-6"
      >
        Deja de imaginar.<br />
        Empieza a construir.
      </h1>

      <!-- Subtitle -->
      <p class="text-sm text-text-muted max-w-xl md:mx-0 mx-auto mb-10 leading-relaxed">
        La comunidad hispanohablante de builders que construyen productos con IA.
      </p>

      <!-- CTA row -->
      <div class="flex flex-col sm:flex-row items-center md:items-start justify-center md:justify-start gap-4 mb-16">
        <CTAButton
          href={heroCTA}
          variant="super-primary"
          label="Unirme por WhatsApp →"
        />
        <CTAButton
          href="https://app.vibecoders.la"
          variant="ghost"
          onDark={true}
          label="Crear mi Perfil"
        />
      </div>
    </div>
  </div>
</section>
