---
import CTAButton from '@/components/ui/CTAButton.astro';

interface Props {
  heroCTA: string;
}

const { heroCTA } = Astro.props;

const stats = [
  { number: '150+', label: 'Builders' },
  { number: '80+', label: 'Apps' },
  { number: '12', label: 'Países' },
];
---

<section class="bg-brand-black min-h-screen flex items-center justify-center px-6 py-12 md:py-20">
  <div class="max-w-[1440px] mx-auto w-full">
    <div class="max-w-4xl mx-auto text-center">
      <!-- H1 -->
      <h1
        class="font-bold leading-[0.95] text-brand-white
               text-[32px] sm:text-[40px] md:text-[56px]
               mb-6"
      >
        Deja de imaginar.<br />
        Empieza a construir.
      </h1>

      <!-- Subtitle -->
      <p class="text-sm text-text-muted max-w-xl mx-auto mb-10 leading-relaxed">
        La comunidad hispanohablante de builders que construyen productos con IA.
      </p>

      <!-- CTA row -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
        <CTAButton
          href={heroCTA}
          variant="super-primary"
          label="Unirme por WhatsApp →"
        />
        <CTAButton
          href="#apps"
          variant="ghost"
          onDark={true}
          label="Ver qué construyen"
        />
      </div>

      <!-- Stats row -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-8 sm:gap-16">
        {stats.map((stat) => (
          <div class="text-center">
            <p class="text-[32px] font-bold leading-[0.95] text-brand-white">
              {stat.number}
            </p>
            <p class="text-sm text-text-muted mt-1">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
