---
import Badge from '@/components/ui/Badge.astro';
import type { ShowcaseApp } from '@/types/showcase-app';

type Props = ShowcaseApp;

const { id, app_name, app_tagline, app_logo_url, app_url, is_verified, founder_display_name, status } = Astro.props;

const initial = app_name.charAt(0).toUpperCase();
---

<a
  href={`/apps/${id}`}
  class="flex flex-col sm:flex-row items-stretch h-full w-full p-6 sm:p-8 bg-surface-charcoal gap-6 sm:gap-8 hover:shadow-soft transition-shadow no-underline"
>
  <div class="w-16 h-16 sm:w-20 sm:h-20 bg-brand-black flex items-center justify-center shrink-0">
    {app_logo_url ? (
      <img
        src={app_logo_url}
        alt={app_name}
        width="80"
        height="80"
        class="w-full h-full object-contain"
        loading="lazy"
      />
    ) : (
      <span class="text-brand-white font-bold text-xl">{initial}</span>
    )}
  </div>

  <div class="flex-1 min-w-0 flex flex-col gap-3">
    <div class="min-w-0">
      <p class="text-[20px] font-bold text-brand-white leading-tight truncate">{app_name}</p>
      {app_tagline && (
        <p class="text-[14px] text-text-muted mt-2 line-clamp-2 leading-relaxed" style="color: #D9D9D6;">
          {app_tagline}
        </p>
      )}
    </div>

    <div class="mt-auto pt-4 flex items-center gap-4">
      {status?.name && (
        <div class="shrink-0">
          <Badge variant="status" value={status.name} />
        </div>
      )}
      <p class="text-[12px]" style="color: #888888;">
        por <span class="font-bold" style="color: #D9D9D6;">{founder_display_name}</span>
      </p>
    </div>
  </div>
</a>
