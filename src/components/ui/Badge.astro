---
interface Props {
  variant: 'tier' | 'category' | 'status' | 'event';
  value: string;
  class?: string;
}

const { variant, value, class: className = '' } = Astro.props;

// Render logic for different badge types
let bgClass = '';
let textClass = '';
let borderClass = '';
let dotClass = '';
let displayValue = value.toUpperCase();

const val = value.toLowerCase();

if (variant === 'tier') {
  if (val === 'founder' || val === 'fundador' || val === 'builder fundador') {
    bgClass = 'bg-[#EFDF00]';
    textClass = 'text-[#000000]';
    displayValue = 'BUILDER FUNDADOR';
  } else if (val === 'pro') {
    bgClass = 'bg-[#000000]';
    textClass = 'text-[#FFFFFF]';
  } else {
    // free or others
    bgClass = 'bg-[#FFFFFF]';
    textClass = 'text-[#000000]';
    borderClass = 'border border-[#000000]';
  }
} else if (variant === 'status') {
  if (val === 'launched' || val === 'live') {
    bgClass = 'bg-[#000000]';
    textClass = 'text-[#FFFFFF]';
    displayValue = 'LAUNCHED';
  } else {
    // beta, building, idea
    bgClass = 'bg-[#FFFFFF]';
    textClass = 'text-[#000000]';
    borderClass = 'border border-[#000000]';
  }
} else if (variant === 'event') {
  if (val === 'en vivo') {
    bgClass = 'bg-[#C0615A]';
    textClass = 'text-[#FFFFFF]';
    dotClass = 'bg-[#FFFFFF]';
  } else if (val.includes('próxima') || val.includes('mañana') || val.includes('día') || val.includes('semana')) {
    bgClass = 'bg-[#EFDF00]';
    textClass = 'text-[#000000]';
  } else {
    // pasada
    bgClass = 'bg-[#FFFFFF]';
    textClass = 'text-[#000000]';
    borderClass = 'border border-[#000000]';
    displayValue = 'PASADA';
  }
} else {
  // category
  bgClass = 'bg-[#FFFFFF]';
  textClass = 'text-[#000000]';
  borderClass = 'border border-[#000000]';
}
---

{displayValue === 'BUILDER FUNDADOR' ? (
  <img
    src="/logo-yellow.png"
    alt="Usuario Builder Fundador"
    title="Usuario Builder Fundador"
    aria-label="Usuario Builder Fundador"
    class={`w-8 h-8 object-cover rounded-full border-[1.5px] border-brand-black shrink-0 ${className}`}
  />
) : (
  <span
    class={`text-[11px] font-bold tracking-[0.1em] px-2.5 py-1 inline-flex items-center gap-1.5 whitespace-nowrap ${bgClass} ${textClass} ${borderClass} ${className}`}
  >
    {dotClass && <span class={`w-1.5 h-1.5 rounded-full ${dotClass} opacity-80`} aria-hidden="true" />}
    {displayValue}
  </span>
)}
