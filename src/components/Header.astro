---
import { communityWhatsAppCTA } from '@/lib/urls';

const navLinks = [
  { label: 'Builders', href: '/builders' },
  { label: 'Apps', href: '/apps' },
  { label: 'Blog', href: '/blog' },
  { label: 'Charlas', href: '/charlas' },
];

const ctaUrl = communityWhatsAppCTA();
---

<header class="sticky top-0 z-50 bg-brand-white w-full border-b border-border">
  <div class="max-w-[1440px] mx-auto px-6 h-[112px] flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-4 font-sans font-bold text-3xl text-brand-black no-underline hover:opacity-80">
      <img src="/logo-yellow.jpg" alt="VibeCoders Logo" class="w-24 h-24 rounded-full border-2 border-brand-black" />
      VibeCoders
    </a>

    <!-- Nav links -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-[13px] font-bold text-brand-black hover:text-brand-blue transition-colors no-underline"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA Button — Primary Black, ZERO border-radius (enforced globally) -->
    <a
      href={ctaUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="bg-brand-black text-brand-white text-sm font-bold px-[15px] py-[10px] hover:opacity-70 transition-opacity no-underline"
    >
      <span class="inline-flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.52 3.48A11.86 11.86 0 0 0 12.06 0C5.5 0 .16 5.34.16 11.9c0 2.1.55 4.14 1.6 5.95L0 24l6.32-1.66a11.8 11.8 0 0 0 5.74 1.46h.01c6.56 0 11.9-5.34 11.9-11.9 0-3.18-1.24-6.16-3.45-8.42zm-8.45 18.3h-.01a9.84 9.84 0 0 1-5.01-1.37l-.36-.21-3.75.98 1-3.66-.24-.38a9.82 9.82 0 0 1-1.5-5.24c0-5.43 4.42-9.85 9.86-9.85 2.63 0 5.11 1.02 6.97 2.88a9.8 9.8 0 0 1 2.89 6.97c0 5.44-4.42 9.87-9.85 9.88zm5.4-7.38c-.3-.15-1.77-.87-2.05-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.95 1.17-.17.2-.35.22-.65.08-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.48-1.76-1.66-2.06-.17-.3-.02-.46.13-.61.14-.14.3-.35.45-.52.15-.18.2-.3.3-.5.1-.2.05-.37-.03-.52-.08-.15-.67-1.62-.92-2.22-.24-.58-.48-.5-.67-.5h-.57c-.2 0-.52.08-.8.37-.27.3-1.05 1.02-1.05 2.5 0 1.47 1.08 2.9 1.23 3.1.15.2 2.12 3.24 5.13 4.54.72.31 1.28.5 1.72.64.72.23 1.37.2 1.89.12.58-.08 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z"/>
        </svg>
        Unirme
      </span>
    </a>
  </div>
</header>
