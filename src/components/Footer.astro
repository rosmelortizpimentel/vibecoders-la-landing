---
import { SITE_NAME } from '@/lib/constants';

const currentYear = new Date().getFullYear();

const columns = [
  {
    title: 'Plataforma',
    links: [
      { label: 'App', href: 'https://app.vibecoders.la' },
      { label: 'Builders', href: '/builders' },
      { label: 'Apps', href: '/apps' },
    ],
  },
  {
    title: 'Contenido',
    links: [
      { label: 'Blog', href: '/blog' },
      { label: 'Charlas', href: '/charlas' },
      { label: 'Recursos', href: '/recursos' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Privacidad', href: '/privacidad' },
      { label: 'Términos', href: '/terminos' },
    ],
  },
];
---

<footer class="bg-brand-white border-t border-border">
  <div class="max-w-[1440px] mx-auto px-6 py-16">
    <!-- Top row: logo + tagline + columns -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <!-- Brand column -->
      <div class="md:col-span-1">
        <a href="/" class="font-sans font-bold text-xl text-brand-black no-underline">
          {SITE_NAME}
        </a>
        <p class="mt-3 text-sm text-brand-black leading-relaxed max-w-[220px]">
          La comunidad de builders que construyen con IA
        </p>
      </div>

      <!-- Nav columns -->
      {columns.map((col) => (
        <div>
          <h3 class="text-[13px] font-bold text-brand-black uppercase tracking-wide mb-4">
            {col.title}
          </h3>
          <ul class="space-y-3">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-[13px] text-brand-black hover:text-brand-blue transition-colors no-underline"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom: copyright -->
    <div class="mt-12 pt-6 border-t border-border">
      <p class="text-[12px] text-brand-black">
        © {currentYear} {SITE_NAME}. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
