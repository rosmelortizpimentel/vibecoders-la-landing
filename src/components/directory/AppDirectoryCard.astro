---
import Badge from '@/components/ui/Badge.astro';
import type { ShowcaseApp } from '@/types/showcase-app';

type Props = ShowcaseApp;

const { app_name, app_tagline, app_logo_url, app_url, is_verified, founder_handle, founder_display_name, founder_avatar_url, status } = Astro.props;

const initial = app_name.charAt(0).toUpperCase();
const founderInitial = founder_display_name.charAt(0).toUpperCase();
---

<a
  href={app_url}
  target="_blank"
  rel="noopener noreferrer"
  class="block bg-surface-charcoal p-6 rounded-none hover:shadow-soft transition-shadow no-underline h-full"
>
  <!-- Logo + Name row -->
  <div class="flex items-center gap-3 mb-4">
    <div class="w-10 h-10 overflow-hidden bg-brand-black flex items-center justify-center shrink-0">
      {app_logo_url ? (
        <img
          src={app_logo_url}
          alt={app_name}
          width="40"
          height="40"
          class="w-full h-full object-contain"
          loading="lazy"
        />
      ) : (
        <span class="text-brand-white font-bold text-sm">{initial}</span>
      )}
    </div>
    <p class="font-bold text-brand-white text-base leading-tight">{app_name}</p>
  </div>

  <!-- Tagline -->
  <p class="text-sm leading-relaxed mb-4 flex-grow line-clamp-2" style="color: #D9D9D6;">{app_tagline ?? ''}</p>

  <!-- Founder info -->
  <div class="flex items-center gap-2 mb-4">
    <div class="w-6 h-6 rounded-full overflow-hidden bg-brand-black flex items-center justify-center shrink-0">
      {founder_avatar_url ? (
        <img
          src={founder_avatar_url}
          alt={founder_display_name}
          width="24"
          height="24"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      ) : (
        <span class="text-brand-white font-bold text-xs">{founderInitial}</span>
      )}
    </div>
    <p class="text-xs" style="color: #888888;">
      por <span class="font-bold" style="color: #D9D9D6;">{founder_display_name}</span>
    </p>
  </div>

  <!-- Status badge -->
  <div class="flex items-center justify-between gap-2 pt-3 border-t" style="border-color: #333333;">
    <Badge variant="status" value={status.name} />
    {is_verified && (
      <span class="text-[10px] font-bold uppercase tracking-wider px-1.5 py-0.5 bg-brand-black text-brand-white">
        Verified
      </span>
    )}
  </div>
</a>