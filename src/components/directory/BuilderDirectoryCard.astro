---
import type { AllBuilder } from '@/types/all-builders';
import Badge from '@/components/ui/Badge.astro';

type Props = AllBuilder;

const { username, display_name, avatar_url, tagline, city, is_pro, is_founder, seeks_partner } = Astro.props;

const initial = display_name.charAt(0).toUpperCase();
---

<a
  href={`/builders/${username}`}
  class="flex flex-col h-full bg-surface-silver border border-border p-6 rounded-none hover:shadow-soft transition-shadow no-underline"
>
  <!-- Avatar + Name row -->
  <div class="flex items-center gap-4 mb-4">
    <div class="w-16 h-16 rounded-full overflow-hidden bg-surface-charcoal flex items-center justify-center shrink-0">
      {avatar_url ? (
        <img
          src={avatar_url}
          alt={display_name}
          width="64"
          height="64"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      ) : (
        <span class="text-brand-white font-bold text-xl">{initial}</span>
      )}
    </div>

    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2 mb-1 flex-wrap">
        <p class="font-bold text-lg text-brand-black leading-tight truncate">{display_name}</p>
        {is_founder && (
          <Badge variant="tier" value="BUILDER FUNDADOR" />
        )}
        {is_pro && (
          <Badge variant="tier" value="PRO" />
        )}
      </div>
      <p class="text-sm mt-0.5 line-clamp-2 leading-relaxed" style="color: #888888;">{tagline ?? ''}</p>
    </div>
  </div>

  <!-- Location row -->
  <div class="flex items-center justify-between gap-2 mb-4">
    {city && (
      <p class="text-sm text-brand-black">
        {city}
      </p>
    )}
  </div>

  <!-- Builder status -->
  <div class="flex items-center gap-4 pt-3 border-t border-border mt-auto">
    <p class="text-sm font-bold text-brand-black">
      {seeks_partner ? 'Busca partner' : 'Abierto a conectar'}
    </p>
  </div>
</a>
