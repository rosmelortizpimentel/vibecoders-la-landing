---
import type { AllBuilder } from '@/types/all-builders';
import Badge from '@/components/ui/Badge.astro';
import SocialLinks from '@/components/ui/SocialLinks.astro';

type Props = AllBuilder;

const { username, display_name, avatar_url, tagline, city, is_pro, is_founder, seeks_partner, social_links } = Astro.props;

const initial = display_name.charAt(0).toUpperCase();

function formatLocation(rawCity?: string | null) {
  if (!rawCity) return null;

  const normalized = rawCity.toLowerCase();
  const countryCodeMap: Record<string, string> = {
    argentina: 'AR',
    españa: 'ES',
    spain: 'ES',
    colombia: 'CO',
    perú: 'PE',
    peru: 'PE',
    méxico: 'MX',
    mexico: 'MX',
    chile: 'CL',
    uruguay: 'UY',
    bolivia: 'BO',
    ecuador: 'EC',
    paraguay: 'PY',
    venezuela: 'VE',
    guatemala: 'GT',
    honduras: 'HN',
    panamá: 'PA',
    panama: 'PA',
    'república dominicana': 'DO',
    'republica dominicana': 'DO',
  };

  const countryCode = Object.entries(countryCodeMap).find(([country]) => normalized.includes(country))?.[1];
  const cityLabel = rawCity
    .split(',')[0]
    ?.trim()
    ?.toUpperCase();

  return countryCode ? `${cityLabel} · ${countryCode}` : cityLabel;
}

const locationLabel = formatLocation(city);
---

<div
  class="relative flex flex-col md:flex-row items-stretch bg-brand-white border border-brand-black p-6 md:p-8 hover:shadow-soft transition-shadow gap-6 md:gap-8 group"
>
  <!-- Full card click overlay (z-10) -->
  <a href={`/builders/${username}`} class="absolute inset-0 z-10" aria-label={`Ver perfil de ${display_name}`}></a>

  <div class="relative z-20 w-20 h-20 md:w-24 md:h-24 rounded-full overflow-hidden bg-[#3D5AFE] flex items-center justify-center shrink-0">
    {avatar_url ? (
      <img
        src={avatar_url}
        alt={display_name}
        width="96"
        height="96"
        class="w-full h-full object-cover"
        loading="lazy"
      />
    ) : (
      <span class="text-brand-white font-bold text-2xl">{initial}</span>
    )}
  </div>

  <div class="flex-1 min-w-0 flex flex-col gap-4">
    <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
      <div class="min-w-0">
        <div class="flex items-center gap-3 flex-wrap">
          <p class="text-[22px] font-bold text-brand-black leading-tight truncate">{display_name}</p>
          {is_founder && <Badge variant="tier" value="BUILDER FUNDADOR" />}
          {is_pro && <Badge variant="tier" value="PRO" />}
        </div>
        {locationLabel && (
          <p class="text-[13px] tracking-[0.22em] uppercase text-brand-black/70 mt-2 truncate">{locationLabel}</p>
        )}
      </div>

      <div class="relative z-20 shrink-0 flex items-center gap-4">
        {social_links && Object.keys(social_links).length > 0 && (
          <SocialLinks socials={social_links} class="text-brand-black" />
        )}
      </div>
    </div>

    {tagline && (
      <p class="text-[16px] text-brand-black leading-relaxed line-clamp-2 mt-2">
        {tagline}
      </p>
    )}

    <div class="mt-auto pt-4 border-t border-brand-black/10 flex items-center justify-between">
      <p class="text-[13px] font-bold uppercase tracking-wider text-brand-black">
        {seeks_partner ? 'Busca partner' : 'Abierto a conectar'}
      </p>
      <span class="text-brand-black opacity-50 hover:opacity-100 transition-opacity">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </span>
    </div>
  </div>
</div>
