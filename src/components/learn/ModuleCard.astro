---
interface Props {
  moduleNumber: number;
  title: string;
  description: string;
  durationMinutes: number;
  prerequisites: string[];
  outcomes: string[];
  slug: string;
}

const {
  moduleNumber,
  title,
  description,
  durationMinutes,
  prerequisites,
  outcomes,
  slug,
} = Astro.props;
---

<a
  href={`/learn/${slug}`}
  class="group block bg-brand-white border border-border p-6 hover:border-brand-black transition-colors no-underline"
>
  <div class="flex items-start gap-4">
    <!-- Module number -->
    <div class="shrink-0 w-12 h-12 bg-brand-black flex items-center justify-center">
      <span class="text-brand-white font-bold text-lg">{moduleNumber}</span>
    </div>

    <div class="flex-1 min-w-0">
      <!-- Duration badge -->
      <div class="mb-2">
        <span class="text-xs font-bold uppercase tracking-wider px-2 py-0.5 bg-surface-silver text-brand-black rounded-none">
          {durationMinutes} min
        </span>
        {prerequisites.length > 0 && (
          <span class="text-xs font-bold uppercase tracking-wider px-2 py-0.5 bg-surface-charcoal text-brand-white rounded-none ml-2">
            Requiere módulo {prerequisites[0]}
          </span>
        )}
      </div>

      <!-- Title -->
      <h3 class="font-bold text-[20px] leading-[0.95] text-brand-black group-hover:opacity-70 transition-opacity mb-2">
        {title}
      </h3>

      <!-- Description -->
      <p class="text-sm leading-relaxed" style="color: #888888;">{description}</p>

      <!-- Outcomes preview -->
      {outcomes.length > 0 && (
        <ul class="mt-3 flex flex-col gap-1">
          {outcomes.slice(0, 2).map((outcome) => (
            <li class="flex items-start gap-2 text-sm text-brand-black">
              <span class="font-bold shrink-0 mt-0.5">✓</span>
              <span>{outcome}</span>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</a>
