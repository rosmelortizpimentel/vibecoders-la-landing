---
import Badge from '@/components/ui/Badge.astro';

interface Props {
  term: string;
  slug: string;
  acronym?: string;
  shortDefinition: string;
  category: string;
}

const { term, slug, acronym, shortDefinition, category } = Astro.props;
---

<a href={`/glosario/${slug}`} class="block bg-surface-silver p-6 hover:shadow-soft transition-shadow no-underline rounded-none group">
  <!-- Term heading -->
  <div class="flex items-start justify-between gap-3 mb-2">
    <h2 class="font-bold text-base text-brand-black leading-tight group-hover:text-brand-blue transition-colors">
      {term}
      {acronym && (
        <span class="text-sm font-normal ml-1" style="color: #888888;">({acronym})</span>
      )}
    </h2>
    <Badge variant="category" value={category} class="shrink-0" />
  </div>

  <!-- Short definition -->
  <p class="text-sm leading-relaxed" style="color: #888888;">
    {shortDefinition}
  </p>
</a>
