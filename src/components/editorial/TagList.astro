---
import Badge from '@/components/ui/Badge.astro';

interface Props {
  tags: string[];
  variant?: 'category' | 'topic';
}

const { tags, variant = 'category' } = Astro.props;

// Badge only accepts 'tier' | 'category' | 'status' — map 'topic' to 'category'
const badgeVariant: 'category' | 'status' | 'tier' = 'category';
---

<div class="flex flex-wrap gap-2">
  {tags.map((tag) => (
    <Badge variant={badgeVariant} value={tag} />
  ))}
</div>
