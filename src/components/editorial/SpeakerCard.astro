---
interface Speaker {
  name: string;
  username?: string;
  role: string;
  bio: string;
  avatarUrl?: string;
  linkedinUrl?: string;
  twitterUrl?: string;
  websiteUrl?: string;
  githubUrl?: string;
  youtubeUrl?: string;
  lovableUrl?: string;
}

interface Props {
  speaker: Speaker;
  onDark?: boolean;
  showBio?: boolean;
}

const { speaker, onDark = true, showBio = true } = Astro.props;

const initial = speaker.name.charAt(0).toUpperCase();

const textMuted = onDark ? 'color: #D9D9D6;' : 'color: #888888;';
const textPrimary = onDark ? 'text-brand-white' : 'text-brand-black';

const profileLink = speaker.username ? `/@${speaker.username}` : null;
---

<div class="flex items-start gap-4">
  <!-- Avatar -->
  {profileLink ? (
    <a href={profileLink} class="w-12 h-12 rounded-full overflow-hidden bg-surface-charcoal flex items-center justify-center shrink-0 hover:opacity-80 transition-opacity no-underline">
      {speaker.avatarUrl ? (
        <img
          src={speaker.avatarUrl}
          alt={speaker.name}
          width="48"
          height="48"
          class="w-full h-full object-cover"
        />
      ) : (
        <span class={`font-bold text-lg ${textPrimary}`}>{initial}</span>
      )}
    </a>
  ) : (
    <div class="w-12 h-12 rounded-full overflow-hidden bg-surface-charcoal flex items-center justify-center shrink-0">
      {speaker.avatarUrl ? (
        <img
          src={speaker.avatarUrl}
          alt={speaker.name}
          width="48"
          height="48"
          class="w-full h-full object-cover"
        />
      ) : (
        <span class={`font-bold text-lg ${textPrimary}`}>{initial}</span>
      )}
    </div>
  )}

  <!-- Info -->
  <div class="flex-1 min-w-0">
    {profileLink ? (
      <a href={profileLink} class={`font-bold text-base hover:opacity-80 transition-opacity no-underline ${textPrimary}`}>{speaker.name}</a>
    ) : (
      <p class={`font-bold text-base ${textPrimary}`}>{speaker.name}</p>
    )}
    <p class="text-sm" style={textMuted}>{speaker.role}</p>
    {showBio && speaker.bio && (
      <p class="text-sm mt-2 leading-relaxed" style={textMuted}>{speaker.bio}</p>
    )}

    <!-- Social links -->
    {(speaker.linkedinUrl || speaker.twitterUrl || speaker.websiteUrl || speaker.githubUrl || speaker.youtubeUrl || speaker.lovableUrl) && (
      <div class="flex items-center gap-3 mt-3">
        {speaker.linkedinUrl && (
          <a
            href={speaker.linkedinUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class={`transition-colors hover:text-brand-blue ${textPrimary}`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        )}
        {speaker.twitterUrl && (
          <a
            href={speaker.twitterUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Twitter / X"
            class={`transition-colors hover:text-brand-blue ${textPrimary}`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        )}
        {speaker.githubUrl && (
          <a
            href={speaker.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class={`transition-colors hover:text-brand-blue ${textPrimary}`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        )}
        {speaker.youtubeUrl && (
          <a
            href={speaker.youtubeUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="YouTube"
            class={`transition-colors hover:text-brand-blue ${textPrimary}`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        )}
        {speaker.websiteUrl && (
          <a
            href={speaker.websiteUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Sitio web"
            class={`transition-colors hover:text-brand-blue ${textPrimary}`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
          </a>
        )}
      </div>
    )}
  </div>
</div>
